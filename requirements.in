# Direct dependencies. Regenerate the pinned requirements.txt with:
#   pip-compile requirements.in
#
# Use Python 3.13 on Windows: TensorFlow has no Windows wheel (stable or
# nightly) for Python 3.14 yet. See README.md "A note on Python 3.14".
matplotlib
notebook
numpy>=2.0
pillow
scikit-learn              # provides the Olivetti Faces facial-recognition dataset
tensorflow>=2.17          # >=2.17 supports NumPy 2.x and Python 3.12
tensorflow-datasets       # provides real datasets (FER-2013, when available)
